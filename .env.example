# Hedera TESTNET credentials — fill with YOUR OWN testnet account from portal.hedera.com.
# TESTNET ONLY. Never put mainnet keys here, and never commit real values (.env is gitignored).
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxxx
HEDERA_EVM_ADDRESS=0xyour_operator_evm_address

# Provide the operator's private key. The deploy/interaction scripts self-select whichever of
# these matches HEDERA_EVM_ADDRESS, so you may set just one (DER or ECDSA-hex both accepted).
HEDERA_OPERATOR_KEY=
HEDERA_HEX_PRIVATE_KEY=
HEDERA_DER_PRIVATE_KEY=
