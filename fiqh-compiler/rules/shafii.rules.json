            { "code": "RISK-1", "field": "risk.loss", "op": "eq", "value": "proportional_to_ownership", "citation": "al-Nawawi, al-Majmu' — loss by capital [scholar-verify]" },
            { "code": "RIBA-2", "field": "returns.rent.basis", "op": "ne", "value": "principal", "citation": "al-Baqarah 2:275 [scholar-verify]" },
            { "code": "GHARAR-1", "field": "returns.buyout.priceSource", "op": "eq", "value": "oracle", "citation": "prohibition of gharar [scholar-verify]" }
          ]
        },
        "mudarabah": {
