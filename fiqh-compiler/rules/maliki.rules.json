          "constraints": [
            { "code": "RIBA-1", "field": "risk.capital_guarantee", "op": "eq", "value": "none", "citation": "Ibn Rushd, Bidayat al-Mujtahid (no guarantee) [scholar-verify]" },
            { "code": "RISK-1", "field": "risk.loss", "op": "eq", "value": "proportional_to_ownership", "citation": "Malik, al-Muwatta — loss by capital [scholar-verify]" },
